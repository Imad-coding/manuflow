# Shopify custom app credentials (see README for setup steps)
# Demo mode: leave both SHOPIFY_* vars empty
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2026-01
SQLITE_DATABASE_PATH=./data/manuflow.sqlite3
BACKUP_DIR=./backups
PORT=3000

# Admin login (required in production)
APP_LOGIN_USERNAME=admin
APP_LOGIN_PASSWORD=change_this_strong_password
SESSION_SECRET=change_this_random_secret

# Shopify webhooks (optional — automatic order sync)
SHOPIFY_WEBHOOK_ENABLED=false
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_MANUAL_WEBHOOK_SECRET=
APP_BASE_URL=https://fullfilforge.store
