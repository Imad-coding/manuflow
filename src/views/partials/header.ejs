<header class="bg-white/80 backdrop-blur-sm border-b border-slate-200/80 px-4 sm:px-5 lg:px-6 py-3.5 sticky top-0 z-10">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
    <div class="min-w-0">
      <h1 class="text-lg sm:text-xl font-semibold text-slate-900 tracking-tight leading-tight"><%= title %></h1>
      <% if (typeof subtitle !== 'undefined' && subtitle) { %>
        <p class="text-[13px] text-slate-500 mt-0.5 max-w-xl leading-snug"><%= subtitle %></p>
      <% } %>
    </div>
    <div class="flex items-center gap-2 shrink-0">
      <%- include('connectionBadge') %>
    </div>
  </div>
</header>
