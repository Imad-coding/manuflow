<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Production Sheet' %> — FulfillForge</title>
  <%- include('partials/printSheetStyles') %>
</head>
<body>
  <% if (typeof notFound !== 'undefined' && notFound) { %>
    <div class="sheet not-found">
      <div class="no-print toolbar">
        <a href="/dashboard">← Back to Dashboard</a>
      </div>
      <h1>Production order not found</h1>
      <p><%= typeof message !== 'undefined' ? message : 'Unable to load this print sheet.' %></p>
    </div>
  <% } else { %>
    <div class="sheet">
      <div class="no-print toolbar">
        <button type="button" class="primary" onclick="window.print()">Print Sheet</button>
        <a href="/orders/<%= order.id %>">← Back to order</a>
        <a href="/dashboard">Dashboard</a>
      </div>

      <%- include('partials/printOrderSheetBody', { order: order, printedAt: printedAt }) %>
    </div>
  <% } %>
</body>
</html>
