<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — FulfillForge</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { sans: ['Inter', '-apple-system', 'BlinkMacSystemFont', 'Segoe UI', 'sans-serif'] },
          colors: {
            shopify: {
              bg: '#f1f2f4',
              surface: '#ffffff',
              border: '#e1e3e5',
              text: '#202223',
              subdued: '#6d7175',
              link: '#005bd3',
              primary: '#303030',
              'primary-hover': '#1a1a1a',
              critical: '#d72c0d',
              success: '#008060',
            },
          },
        },
      },
    };
  </script>
  <link rel="stylesheet" href="/css/app.css">
</head>
<body class="app-body" data-page="<%= typeof activePage !== 'undefined' ? activePage : '' %>"<% if (typeof orderId !== 'undefined' && orderId) { %> data-order-id="<%= orderId %>"<% } %>>
  <%- include('partials/appNav') %>
  <main class="app-main">
    <div class="app-container">
      <%- body %>
    </div>
  </main>
  <div id="toast" class="app-toast hidden" role="status" aria-live="polite"></div>
  <script src="/js/app.js"></script>
</body>
</html>
